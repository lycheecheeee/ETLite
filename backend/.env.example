# ===========================================
# Net 仔 Podcast System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Application Settings
# ===========================================
APP_NAME=Net 仔 Podcast System
DEBUG=true
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-here

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://netzai:password@localhost:5432/netzai_db
# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379/0
# ===========================================
# LLM Configuration - BigModel GLM (智譜AI)
# ===========================================
# Get your API key from: https://open.bigmodel.cn
BIGMODEL_API_KEY=your-bigmodel-api-key-here
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# Fast model for speed, quality model for better output
BIGMODEL_MODEL=glm-4-flash
BIGMODEL_MODEL_QUALITY=glm-4-air
# ===========================================
# LLM Provider Selection
# ===========================================
# Options: "bigmodel" or "openai"
LLM_PROVIDER=bigmodel
# ===========================================
# OpenAI Configuration (Backup LLM)
# ===========================================
# Get your key from: https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# ===========================================
# TTS Configuration - Cantonese AI (Primary)
# ===========================================
# Get your API key from: https://cantonese.ai/api-keys
# Browse voices at: https://cantonese.ai/voices
CANTONESE_AI_API_URL=https://cantonese.ai/api/tts
CANTONESE_AI_API_KEY=your-cantonese-ai-api-key-here
# Voice ID: Browse available voices at https://cantonese.ai/voices
# Example voice ID (replace with your preferred voice):
CANTONESE_AI_VOICE_ID=2725cf0f-efe2-4132-9e06-62ad84b2973d
# Rate limiting: Pro = 10 req/min, set to 8 for buffer
CANTONESE_AI_TTS_CONCURRENCY=8
# Max text length per request (API supports up to 5000 chars)
CANTONESE_AI_CHUNK_SIZE=500
# ===========================================
# TTS Provider Selection
# ===========================================
# Options: "cantonese_ai" or "azure"
TTS_PROVIDER=cantonese_ai
# ===========================================
# Azure TTS Configuration (Backup)
# ===========================================
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_VOICE=zh-HK-HiuMaanNeural
# ===========================================
# Storage Configuration (MinIO/S3)
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=podcast-audio
MINIO_SECURE=false
# ===========================================
# Celery Configuration
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO
