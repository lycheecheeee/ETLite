# App Settings
APP_NAME="Net 仔 Podcast System"
DEBUG=true
SECRET_KEY="your-secret-key-change-in-production"

# Database
DATABASE_URL=postgresql://netzai:password@localhost:5432/netzai_db
REDIS_URL=redis://localhost:6379/0

# Azure TTS (Speech Service)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_VOICE=zh-HK-HiuMaanNeural

# Cantonese AI TTS (Primary TTS Service)
CANTONESE_AI_API_KEY=your_cantonese_ai_api_key
CANTONESE_AI_VOICE_ID=087b8717-9ff7-49fe-9ab5-9c30b15769ee  # Mina voice

# OpenAI (for content generation and chatbot)
OPENAI_API_KEY=your_openai_api_key

# MinIO/S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=podcast-audio
AWS_S3_USE_MINIO=true

# Celery Broker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
