# Net 仔 Podcast System - Environment Variables
# 複製此文件為 .env 並填入你的配置

# ====================
# Azure TTS Configuration
# 獲取地址：https://portal.azure.com/#create/Microsoft.CognitiveServicesSpeechServices
# ====================
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_VOICE=zh-HK-HiuMaanNeural

# ====================
# Cantonese AI TTS Configuration (推薦 - 高質素粵語)
# 已配置 API Key，可以直接使用
# ====================
CANTONESE_AI_API_URL=https://cantonese.ai/api/tts
CANTONESE_AI_API_KEY=sk-o0sqn7wHhgsSqHoNW0j58q0f0vwcms9
CANTONESE_AI_VOICE_ID=2725cf0f-efe2-4132-9e06-62ad84b2973d

# ====================
# OpenAI API Configuration (Optional)
# 獲取地址：https://platform.openai.com/api-keys
# ====================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ====================
# Database Configuration
# ====================
DATABASE_URL=postgresql+asyncpg://netzai:password@localhost:5432/netzai_db
POSTGRES_USER=netzai
POSTGRES_PASSWORD=password
POSTGRES_DB=netzai_db

# ====================
# Redis Configuration
# ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ====================
# MinIO/S3 Configuration
# ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=podcast-audio
AWS_S3_USE_MINIO=true

# ====================
# Application Settings
# ====================
APP_NAME="Net 仔 Podcast System"
DEBUG=true
SECRET_KEY=change-this-in-production-to-a-random-string

# ====================
# Server Configuration
# ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ====================
# Logging
# ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ====================
# Monitoring
# ====================
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ====================
# Frontend URLs (for CORS)
# ====================
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ====================
# File Upload Limits
# ====================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_AUDIO_FORMATS=wav,mp3,m4a

# ====================
# Email Configuration (Optional - for notifications)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ====================
# WhatsApp Business API (Optional)
# ====================
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
